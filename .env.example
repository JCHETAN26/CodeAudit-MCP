# CodeSentinel Environment Configuration
# Copy this file to .env and fill in your values

# ================================
# OPTION 1: Self-Hosted VPS (Recommended for Friends & Family)
# ================================
# VPS_API_URL=http://YOUR-VPS-IP:5000/review
# Example: VPS_API_URL=http://192.0.2.100:5000/review

# ================================
# OPTION 2: Together.AI API (Requires Billing)
# ================================
# TOGETHER_API_KEY=tgp_v1_XXXXXXXXXXXX
# Get from: https://api.together.ai/settings/api-keys
# Note: Requires payment method on file (even for free tier)

# ================================
# OPTION 3: HF Spaces (Free tier pauses, paid $8/mo)
# ================================
# CODESENTINEL_API_URL=https://username-codesentinel.hf.space/review

# ================================
# OPTION 4: Local Model (Requires GPU/16GB RAM)
# ================================
# USE_LOCAL_MODEL=true

# ================================
# Priority Order (First set wins)
# ================================
# 1. VPS_API_URL (if set)
# 2. TOGETHER_API_KEY (if set)
# 3. USE_LOCAL_MODEL (if true)
# 4. HF Spaces URL (fallback)
