{
  "name": "codeaudit-mcp",
  "version": "1.0.0",
  "description": "CodeAudit-MCP: Principal Engineer-grade code review for Claude Desktop. Security, reliability, and scalability audits.",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "codeaudit-mcp": "bin/cli.js"
  },
  "files": [
    "build",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc --project tsconfig.json",
    "start": "node build/index.js",
    "dev": "npm run build && node build/index.js",
    "setup": "node bin/setup.js",
    "test:validate": "node scripts/test-dependencies.js",
    "test:tools": "node scripts/test-tools.js",
    "test:e2e": "npm run build && node scripts/test-e2e.js",
    "test": "npm run test:validate && npm run test:tools && npm run test:e2e",
    "demo": "npm run build && node scripts/demo.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "code-review",
    "ai",
    "security",
    "semgrep",
    "typescript"
  ],
  "author": "Chetan Jitendra",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JCHETAN26/CodeAudit-MCP"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.2"
  }
}
